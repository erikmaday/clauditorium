# Claude API Server Configuration
# Copy this file to .env and modify as needed

# Server host address
# Use 0.0.0.0 to allow external connections
CLAUDE_API_HOST=127.0.0.1

# Server port
CLAUDE_API_PORT=5051

# Request timeout in seconds
# Increase for complex prompts that take longer to process
CLAUDE_API_TIMEOUT=120

# Maximum JSON request body size accepted by the API
# Examples: 256kb, 1mb, 5mb
CLAUDE_API_BODY_LIMIT=1mb

# Enable CORS for browser-based clients
# Set to "true" to allow cross-origin requests
CLAUDE_API_CORS=false

# Logging level (DEBUG, INFO, WARN, ERROR)
CLAUDE_API_LOG_LEVEL=INFO

# Optional API key required for /ask and /chat requests
# When set, clients must include x-api-key header
CLAUDE_API_KEY=
