# Claude API Server Configuration
# Copy this file to .env and modify as needed

# Server host address
# Use 0.0.0.0 to allow external connections
CLAUDE_API_HOST=127.0.0.1

# Server port
CLAUDE_API_PORT=5051

# Request timeout in seconds
# Increase for complex prompts that take longer to process
CLAUDE_API_TIMEOUT=120

# Startup readiness check timeout in seconds for `claude --version`
CLAUDE_API_STARTUP_CHECK_TIMEOUT=5

# Rate limit settings for /ask and /chat
# Set max requests to 0 to disable rate limiting
CLAUDE_API_RATE_LIMIT_WINDOW_SECONDS=60
CLAUDE_API_RATE_LIMIT_MAX_REQUESTS=0

# Max number of readiness entries retained in memory for /health/history
CLAUDE_API_HEALTH_HISTORY_LIMIT=25

# Conversation lifecycle settings
# Inactivity TTL before a conversation is expired
CLAUDE_API_CONVERSATION_TTL_SECONDS=86400
# Max in-memory conversations before oldest inactive are evicted
CLAUDE_API_MAX_CONVERSATIONS=1000
# Soft context budget thresholds (character-based metadata only, no hard rejection)
CLAUDE_API_CONTEXT_WARN_CHARS=80000
CLAUDE_API_CONTEXT_TARGET_CHARS=120000

# Maximum JSON request body size accepted by the API
# Examples: 256kb, 1mb, 5mb
CLAUDE_API_BODY_LIMIT=1mb

# Enable CORS for browser-based clients
# Set to "true" to allow cross-origin requests
CLAUDE_API_CORS=false

# Logging level (DEBUG, INFO, WARN, ERROR)
CLAUDE_API_LOG_LEVEL=INFO

# If true, /health returns 503 when Claude CLI readiness is not ready
CLAUDE_API_STRICT_HEALTH=false

# Optional API key required for /ask and /chat requests
# When set, clients must include x-api-key header
CLAUDE_API_KEY=
