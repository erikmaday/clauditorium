{
  "name": "clauditorium",
  "version": "1.3.0",
  "description": "REST API wrapper for the Claude CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clauditorium": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "openapi:lint": "tsx scripts/lint-openapi.ts",
    "openapi:validate": "tsx scripts/validate-openapi.ts",
    "contract:test": "vitest run test/contract",
    "api:contract:check": "npm run openapi:lint && npm run openapi:validate && npm run contract:test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "api",
    "rest",
    "server",
    "cli",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erikmaday/clauditorium.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "@types/supertest": "^6.0.3",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "express-list-endpoints": "^7.1.1",
    "openapi-response-validator": "^12.1.3",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
